rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // A signed-in user may update ONLY the denormalized counter fields
    // (voteScore, avgRating, ratingCount) on any spot - this is what the
    // vote/rating transactions touch. No other fields may change.
    function onlyCountersChanged() {
      return request.resource.data.diff(resource.data)
        .affectedKeys()
        .hasOnly(['voteScore', 'avgRating', 'ratingCount']);
    }

    match /users/{uid} {
      allow read: if signedIn();
      allow write: if request.auth.uid == uid;
    }

    match /spots/{spot} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid;

      // Full edits: only the owner. Counter updates: anyone signed in, but
      // strictly limited to the three denormalized fields.
      allow update: if signedIn() && (
        resource.data.createdBy == request.auth.uid || onlyCountersChanged()
      );
      allow delete: if signedIn()
        && resource.data.createdBy == request.auth.uid;

      match /comments/{c} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.resource.data.authorId == request.auth.uid;
        allow delete: if signedIn()
          && resource.data.authorId == request.auth.uid;
      }

      match /votes/{uid} {
        allow read: if signedIn();
        allow write: if request.auth.uid == uid;
      }

      match /ratings/{uid} {
        allow read: if signedIn();
        allow write: if request.auth.uid == uid;
      }
    }

    // ---- Non-place sections: market, tools (software & skills), news ----
    // Same model as spots: owner does full edits; any signed-in user may touch
    // only the denormalized counters; votes/ratings/comments keyed by uid.
    // Scoped to these three collection names at every level so this never
    // overlaps the dedicated /users, /spots, or /reports rules.
    function isSection(name) {
      return name in ['market', 'tools', 'news'];
    }

    match /{section}/{item} {
      allow read: if signedIn() && isSection(section);
      allow create: if signedIn() && isSection(section)
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if signedIn() && isSection(section)
        && (resource.data.createdBy == request.auth.uid || onlyCountersChanged());
      allow delete: if signedIn() && isSection(section)
        && resource.data.createdBy == request.auth.uid;

      match /comments/{c} {
        allow read: if signedIn() && isSection(section);
        allow create: if signedIn() && isSection(section)
          && request.resource.data.authorId == request.auth.uid;
        allow delete: if signedIn() && isSection(section)
          && resource.data.authorId == request.auth.uid;
      }
      match /votes/{uid} {
        allow read: if signedIn() && isSection(section);
        allow write: if request.auth.uid == uid && isSection(section);
      }
      match /ratings/{uid} {
        allow read: if signedIn() && isSection(section);
        allow write: if request.auth.uid == uid && isSection(section);
      }
    }

    match /reports/{report} {
      allow create: if signedIn()
        && request.resource.data.reportedBy == request.auth.uid;
      // Only the owner reviews these in the Firebase console.
      allow read, update, delete: if false;
    }
  }
}
