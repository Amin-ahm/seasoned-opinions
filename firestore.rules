rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // A signed-in user may update ONLY the denormalized counter fields
    // (voteScore, avgRating, ratingCount) on any spot - this is what the
    // vote/rating transactions touch. No other fields may change.
    function onlyCountersChanged() {
      return request.resource.data.diff(resource.data)
        .affectedKeys()
        .hasOnly(['voteScore', 'avgRating', 'ratingCount']);
    }

    match /users/{uid} {
      allow read: if signedIn();
      allow write: if request.auth.uid == uid;
    }

    match /spots/{spot} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid;

      // Full edits: only the owner. Counter updates: anyone signed in, but
      // strictly limited to the three denormalized fields.
      allow update: if signedIn() && (
        resource.data.createdBy == request.auth.uid || onlyCountersChanged()
      );
      allow delete: if signedIn()
        && resource.data.createdBy == request.auth.uid;

      match /comments/{c} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.resource.data.authorId == request.auth.uid;
        allow delete: if signedIn()
          && resource.data.authorId == request.auth.uid;
      }

      match /votes/{uid} {
        allow read: if signedIn();
        allow write: if request.auth.uid == uid;
      }

      match /ratings/{uid} {
        allow read: if signedIn();
        allow write: if request.auth.uid == uid;
      }
    }

    match /reports/{report} {
      allow create: if signedIn()
        && request.resource.data.reportedBy == request.auth.uid;
      // Only the owner reviews these in the Firebase console.
      allow read, update, delete: if false;
    }
  }
}
